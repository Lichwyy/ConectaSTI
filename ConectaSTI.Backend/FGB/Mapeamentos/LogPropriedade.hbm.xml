<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="FGB.Dominio" namespace="FGB.Dominio.Entidades">
  <class name="LogPropriedade" table="log_propriedade" lazy="false">
    <id name="Id" type="long" column="id">
      <generator class="sequence">
        <param name="sequence">log_propriedade_id_seq</param>
      </generator>
    </id>

    <many-to-one name="LogEntidade" class="LogEntidade" column="log_entidade_id" not-null="true" />
    <property name="LogEntidadeId"  column="log_entidade_id"  type="long"       not-null="true" insert="false" update="false" />
    <property name="Propriedade"    column="propriedade"      type="string"     not-null="true" />
    <property name="ValorAnterior"  column="valor_anterior"   type="string"     not-null="false" />
    <property name="ValorAtual"     column="valor_atual"      type="string"     not-null="false" />
  </class>
</hibernate-mapping>
