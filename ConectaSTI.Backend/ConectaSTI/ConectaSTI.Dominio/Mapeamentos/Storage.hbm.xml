<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"  assembly="ConectaSTI.Dominio"  namespace="ConectaSTI.Dominio.Entidades">
  <class name="Storage" table="storage" lazy="false" batch-size="100">
    <id name="Id" type="long" column="id">
      <generator class="sequence">
        <param name="sequence">storage_id_seq</param>
      </generator>
    </id>

    <property   name="CriadoEm"           column="criadoem"           type="DateTime"   not-null="false"  />
    <property   name="UltimaAlteracao"    column="ultimaalteracao"    type="DateTime"   not-null="false"  />


    <property name="Chave"      column="chave"      type="string"       not-null="true" />
    <property name="Valor"      column="valor"      type="string"       not-null="false" />
    <property name="Validade"   column="validade"   type="DateTime"     not-null="true" />
  </class>
</hibernate-mapping>
