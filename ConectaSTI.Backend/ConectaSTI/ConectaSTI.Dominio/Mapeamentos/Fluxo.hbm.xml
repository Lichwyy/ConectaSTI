<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"  assembly="ConectaSTI.Dominio"  namespace="ConectaSTI.Dominio.Entidades">
  <class name="Fluxo" table="fluxo" lazy="false" batch-size="100">
    <id name="Id" type="long" column="id">
      <generator class="sequence">
        <param name="sequence">fluxo_id_seq</param>
      </generator>
    </id>

    <property   name="CriadoEm"           column="criadoem"           type="DateTime"   not-null="false"  />
    <property   name="UltimaAlteracao"    column="ultimaalteracao"    type="DateTime"   not-null="false"  />

    <property   name="Nome"     column="nome"   type="string"   not-null="true" />
	  
    <bag name="Operacoes" inverse="true" cascade="all-delete-orphan" lazy="false">
      <key column="fluxo_id" not-null="true" />
      <one-to-many class="Operacao" />
    </bag>
  </class>
</hibernate-mapping>