<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2"  assembly="ConectaSTI.Dominio"  namespace="ConectaSTI.Dominio.Entidades">
  <class name="Operacao" table="operacao" lazy="false" batch-size="100">
    <id name="Id" type="long" column="id">
      <generator class="sequence">
        <param name="sequence">operacao_id_seq</param>
      </generator>
    </id>

    <property   name="CriadoEm"           column="criadoem"           type="DateTime"   not-null="false"  />
    <property   name="UltimaAlteracao"    column="ultimaalteracao"    type="DateTime"   not-null="false"  />


    <property name="Body" column="body" type="string"/>
    <property name="Header" column="header" type="string"/>
    <property name="Ordem" column="ordem" type="int" not-null="true" />
    <property name="NoId" column="no_id" type="long" not-null="true" />
    <property name="FluxoId" column="fluxo_id" type="long" not-null="true" />
    <property name="Repetir" column="repetir" type="bool"/>
    <property name="Erro" column="erro"   />
    <property name="MaximoRepeticao" column="maximo_repeticao" type="int"/>
  </class>
</hibernate-mapping>