    <property   name="CriadoEm"           column="criadoem"           type="DateTime"   not-null="false"  />
    <property   name="UltimaAlteracao"    column="UltimaAlteracao"    type="DateTime"   not-null="false"  />


    <property name="Tipo" column="Tipo" type="string" not-null="true" />
    <property name="FuncaoId" column="FuncaoId" type="long" not-null="false" />
    <property name="EndPointId" column="EndPointId" type="long" not-null="false" />
  </class>
</hibernate-mapping>