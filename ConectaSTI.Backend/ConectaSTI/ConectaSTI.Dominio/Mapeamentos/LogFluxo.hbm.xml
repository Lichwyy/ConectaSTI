<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="ConectaSTI.Dominio" namespace="ConectaSTI.Dominio.Entidades.Logs">
  <class name="LogFluxo" table="log_fluxo" lazy="false" batch-size="100">
    <id name="Id" type="long" column="id">
      <generator class="sequence">
        <param name="sequence">log_fluxo_id_seq</param>
      </generator>
    </id>

    <property name="CriadoEm" column="criadoem" type="DateTime" not-null="false" />
    <property name="UltimaAlteracao" column="ultimaalteracao" type="DateTime" not-null="false" />

    <property name="FluxoId" column="fluxo_id" type="long" not-null="false" />
    <property name="Versao" column="versao" type="int" not-null="true" />
    <property name="FluxoVersionadoId" column="fluxo_versionado_id" type="long" not-null="false" />
    <property name="Nome" column="nome" type="string" not-null="false" />
    <property name="LogFluxoPaiId" column="log_fluxo_pai_id" type="long" not-null="false" />
    <property name="IniciadoEm" column="iniciado_em" type="DateTime" not-null="false" />
    <property name="FinalizadoEm" column="finalizado_em" type="DateTime" not-null="false" />
    <property name="DuracaoMs" column="duracao_ms" type="int" not-null="true" />
    <property name="QuantidadeOperacoes" column="quantidade_operacoes" type="int" not-null="true" />
    <property name="OperacoesExecutadas" column="operacoes_executadas" type="int" not-null="true" />
    <property name="OperacoesComSucesso" column="operacoes_com_sucesso" type="int" not-null="true" />
    <property name="OperacoesComFalha" column="operacoes_com_falha" type="int" not-null="true" />
    <property name="StatusHttp" column="status_http" type="int" not-null="true" />
    <property name="Sucesso" column="sucesso" type="bool" not-null="true" />
  </class>
</hibernate-mapping>
